# ==========================================
# CSDAC Internship Portal - Production Config
# ==========================================

# 1. Environment Type
NODE_ENV=production

# 2. Database Connection (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@hostname:5432/dbname?sslmode=require"

# 3. NextAuth Configuration
# The canonical URL of your production deployment
NEXTAUTH_URL="https://internships.cdac.in"
# Generate via: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_SECURE_GENERATED_SECRET"

# 4. Optional Integrations
# SENTRY_DSN=""
# OPENAI_API_KEY=""
